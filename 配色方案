@keyframes breathe {
    0% {
        transform: scale(1);
        box-shadow: 0 20px 25px -5px #0000001a,0 8px 10px -6px #0000001a
    }

    5% {
        transform: scale(.99);
        box-shadow: 0 20px 25px -5px #0000001a,0 8px 10px -6px #0000001a
    }

    25% {
        transform: scale(1.04);
        box-shadow: 0 0 0 6px #8b7bdb4d,0 35px 70px -12px #8b7bdb80
    }

    50% {
        transform: scale(1);
        box-shadow: 0 20px 25px -5px #0000001a,0 8px 10px -6px #0000001a
    }

    55% {
        transform: scale(.99);
        box-shadow: 0 20px 25px -5px #0000001a,0 8px 10px -6px #0000001a
    }

    75% {
        transform: scale(1.04);
        box-shadow: 0 0 0 6px #8b7bdb4d,0 35px 70px -12px #8b7bdb80
    }

    to {
        transform: scale(1);
        box-shadow: 0 20px 25px -5px #0000001a,0 8px 10px -6px #0000001a
    }
}

.animate-breathe {
    animation: 2s cubic-bezier(.4,0,.2,1) breathe
